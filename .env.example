# ===========================================
# Go-Hunter Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# ----- Server Configuration -----
# Host address the server binds to (use 0.0.0.0 for all interfaces)
SERVER_HOST=0.0.0.0

# Port the HTTP server listens on
SERVER_PORT=8080

# Environment: development, staging, production
# - development: enables debug logging, auto-migrations, text log format
# - staging/production: info logging, JSON log format, no auto-migrations
SERVER_ENV=development

# ----- Database Configuration -----
# PostgreSQL connection settings
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=gohunter
DATABASE_PASSWORD=your_secure_password_here
DATABASE_NAME=gohunter

# SSL mode for database connection
# Options: disable, require, verify-ca, verify-full
# Use 'require' or higher in production
DATABASE_SSLMODE=disable

# ----- Redis Configuration -----
# Redis is used for background job queues (Asynq) and caching
REDIS_HOST=localhost
REDIS_PORT=6379

# Leave empty if Redis has no password (development only)
REDIS_PASSWORD=

# ----- Authentication (JWT) -----
# Secret key for signing JWT tokens
# IMPORTANT: Use a strong, random string of at least 32 characters in production
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_minimum_32_characters

# JWT token expiry in hours
JWT_EXPIRY_HOURS=24

# ----- Encryption -----
# age encryption key for securing cloud credentials at rest
# This key is used to encrypt sensitive credential data stored in the database
#
# Generate a new key with: age-keygen
# The key looks like: AGE-SECRET-KEY-1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#
# IMPORTANT:
# - Keep this key secure and never commit it to version control
# - Both server and worker need the same key to encrypt/decrypt credentials
# - If you lose this key, all stored credentials become unrecoverable
ENCRYPTION_KEY=

# ----- Rate Limiting -----
# Number of requests allowed per window
RATE_LIMIT_REQUESTS=100

# Rate limit window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# ----- Admin User (for seeding) -----
# Used by scripts/seed.go to create the initial admin user
# These are only needed when running the seed script
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_BEFORE_USE
ADMIN_NAME=Admin

# ===========================================
# Cloud Provider Credentials (Optional)
# ===========================================
# Cloud credentials are typically stored encrypted in the database and
# managed through the web UI. The environment variables below are for
# reference only and show the credential fields used by each provider.
#
# In production, add credentials through the Go-Hunter web interface
# which encrypts them using the ENCRYPTION_KEY above.

# ----- AWS -----
# Required fields when adding AWS credentials:
# - access_key_id: AWS Access Key ID
# - secret_access_key: AWS Secret Access Key
# Optional fields:
# - assume_role_arn: ARN of IAM role to assume (for cross-account access)
# - external_id: External ID for assume role (added security)
# - regions: Comma-separated list of regions to scan (empty = all regions)
#
# Example regions: us-east-1,us-west-2,eu-west-1
#
# Required IAM permissions for asset discovery:
# - ec2:DescribeInstances
# - s3:ListAllMyBuckets, s3:GetBucketLocation, s3:GetBucketAcl
# - route53:ListHostedZones, route53:ListResourceRecordSets
# - elasticloadbalancing:DescribeLoadBalancers
# - sts:GetCallerIdentity (for credential validation)

# ----- Azure -----
# Required fields when adding Azure credentials:
# - tenant_id: Azure AD tenant ID
# - client_id: Azure AD application (client) ID
# - client_secret: Azure AD application client secret
# Optional fields:
# - subscriptions: Comma-separated subscription IDs (empty = all accessible)
#
# Required Azure RBAC permissions:
# - Reader role on target subscriptions
# - Or specific: Microsoft.Compute/virtualMachines/read,
#   Microsoft.Storage/storageAccounts/read,
#   Microsoft.Network/publicIPAddresses/read,
#   Microsoft.Network/loadBalancers/read,
#   Microsoft.Network/dnszones/read

# ----- GCP -----
# Required fields when adding GCP credentials:
# - service_account_json: Full JSON content of service account key file
# Optional fields:
# - projects: Comma-separated project IDs (empty requires project list)
#
# Required GCP IAM roles:
# - roles/compute.viewer
# - roles/storage.objectViewer
# - roles/dns.reader
# Or custom role with:
# - compute.instances.list, storage.buckets.list, dns.managedZones.list

# ----- Cloudflare -----
# Required fields when adding Cloudflare credentials:
# - api_token: Cloudflare API token (recommended)
# OR legacy authentication:
# - api_key: Global API key
# - email: Account email (required with api_key)
# Optional fields:
# - zone_ids: Comma-separated zone IDs (empty = all accessible zones)
#
# Required API token permissions:
# - Zone:Read
# - DNS:Read

# ----- DigitalOcean -----
# Required fields when adding DigitalOcean credentials:
# - api_token: DigitalOcean personal access token
#
# Required token scopes:
# - read (for asset discovery)
#
# Generate at: https://cloud.digitalocean.com/account/api/tokens

# ===========================================
# Advanced Configuration (Optional)
# ===========================================

# ----- Worker Configuration -----
# The worker uses the same Redis configuration as the server
# Number of concurrent workers is configured in code (default: 10)

# ----- Scheduler -----
# The worker includes a built-in scheduler that checks for scheduled scans
# every minute. No additional configuration is needed.
